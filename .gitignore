# Environments
.env
.env.local
*.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Node / frontend
node_modules/
dist/
.vite/

# Editors
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local app database (PHI — never commit)
data/

# ChromaDB write-ahead artefacts (keep the data, drop the WAL)
vector_store/chroma_db/*.wal
vector_store/chroma_ctx_db/*.wal
vector_store/chroma_rechunked_db/*.wal

# Build cache for the contextual index (regenerated by build_contextual_index.py).
# Not committed: a stale structural-only cache would block a future --llm rebuild
# from generating blurbs.
vector_store/context_cache.json
