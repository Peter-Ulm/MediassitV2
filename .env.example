# ───────────────── MediAssist root .env ─────────────────
# Copy to .env and fill in any provider-specific values.
# All keys have safe defaults; only OPENAI_API_KEY is required if you set
# LLM_PROVIDER=openai.

# ── LLM provider ────────────────────────────────────────
# "ollama" (default, offline)  |  "openai"
LLM_PROVIDER=ollama

# OpenAI — needed only when LLM_PROVIDER=openai
OPENAI_API_KEY=
# Recommended: gpt-4o-mini (cheaper than retired gpt-3.5-turbo, smarter,
# supports native JSON mode). Upgrade to gpt-4o for higher quality.
OPENAI_MODEL=gpt-4o-mini

# Ollama — used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# llama3.2:3b is the default — ~3x faster than 7B on CPU (the target machine).
# For maximum reasoning depth (slower): set OLLAMA_MODEL=mistral:7b-instruct
# after `ollama pull mistral:7b-instruct`.
OLLAMA_MODEL=llama3.2:3b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096
OLLAMA_WARMUP_ON_STARTUP=true

# ── Knowledge base ──────────────────────────────────────
# Retrieval points at the contextual index (built by scripts/build_contextual_index.py).
# Hybrid BM25 is OFF: the eval showed it lowered ranking quality (MRR) on the STG.
CHROMA_PATH=vector_store/chroma_ctx_db
CHROMA_COLLECTION=mediassist_stg_ctx
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=5
RERANK_TOP_N=3
USE_HYBRID=false

# ── Persistence + Auth ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/mediassist.db
# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── API ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
